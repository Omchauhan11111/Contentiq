# =============================================
# ContentIQ — Environment Configuration
# =============================================
# Copy this file and fill in your values.
# Never commit real secrets to version control.

# --- Server ---
PORT=3000
NODE_ENV=production

# --- MongoDB ---
# Replace <db_password> with your actual Atlas password
MONGODB_URI=mongodb+srv://dgw_user:dgw_pass@cluster0.rwhkq91.mongodb.net/?appName=Cluster0
DB_NAME=contentiq


# MONGODB_URI=mongodb+srv://dgw_user:dgw_pass@cluster0.rwhkq91.mongodb.net/?appName=Cluster0
# DB_NAME=contentiq
# --- JWT (Authentication) ---
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=7d

# --- n8n (Automation) ---
# Your n8n instance base URL (e.g. https://your-n8n.railway.app)
N8N_BASE_URL=https://omsinghdgw.app.n8n.cloud
N8N_WEBHOOK_PATH=/webhook-test/contentiq
# --- CORS ---
# Frontend URL — update when deploying
FRONTEND_URL=http://localhost:5500

# --- Optional: Email (for future notifications) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password